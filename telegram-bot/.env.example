# ═══════════════════════════════════════════════════════════════════
#  Telegram Forwarder Bot — Environment Variables
#  Copy this file to .env for local dev, or paste into Railway's
#  Variables tab for production.
# ═══════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram API credentials — get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=


# ── SESSION (choose one) ──────────────────────────────────────────────────────

# Option A (recommended for Railway — survives redeployments):
# Export your session string once locally, then paste here.
# Run: python -c "
#   from telethon.sessions import StringSession
#   from telethon import TelegramClient
#   import asyncio, os
#   async def main():
#       c = TelegramClient(StringSession(), int(os.environ['TELEGRAM_API_ID']), os.environ['TELEGRAM_API_HASH'])
#       await c.start()
#       print('SESSION_STRING=' + c.session.save())
#   asyncio.run(main())"
SESSION_STRING=

# Option B (local/volume only — wiped on Railway redeploy unless you mount a volume):
# Leave blank to use the default path (telegram-bot/sessions/userbot)
# SESSION_PATH=/data/sessions/userbot

# Userbot 2 session string (for /dualcopy 2× speed feature)
SESSION_STRING_2=


# ── DATABASE ──────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# On Railway: add a volume at /data and set DB_PATH=/data/forwarder.db
# so your forward rules survive redeployments.
# Leave blank to use the default (telegram-bot/data/forwarder.db — wiped on redeploy)
DB_PATH=/data/forwarder.db


# ── OPTIONAL DEFAULTS ─────────────────────────────────────────────────────────

# Default source channel ID (used as pre-fill in /copy wizard)
# Can be overridden at runtime via the bot.
SOURCE_CHANNEL=

# Default destination channel ID
DEST_CHANNEL=

# Replace all @usernames and t.me links in captions with this value.
# Leave blank to keep original captions.
CAPTION_REPLACE=

# Notify every N files copied (0 = off)
NOTIFY_EVERY=100

# Only copy files with these extensions (comma-separated, e.g. mkv,mp4)
# Leave blank to copy all files.
ALLOWED_EXTS=

# Set to "true" to skip text-only messages (only copy media)
SKIP_TEXT=false
